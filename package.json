  "version": "0.0.0",
  "type": "module",
  "main": "out/main/index.cjs",
  "scripts": {
    "dev": "env -u ELECTRON_RUN_AS_NODE electron-vite dev",
    "build": "electron-vite build",
    "lint": "eslint .",
    "preview": "electron-vite preview",
    "build:win": "npm run build && electron-builder --win --config electron-builder.yml",
